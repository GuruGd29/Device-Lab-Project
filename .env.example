# Copy to .env and adjust. Consumed by the cloud plane and lab agent.

# --- Cloud Control Plane ---
DATABASE_URL=postgres://devicelab:devicelab@localhost:5432/devicelab
NATS_URL=nats://localhost:4222
PORT=8080
RUN_MIGRATIONS=1

# Shared secret the lab agent presents when opening its control tunnel to the cloud plane.
AGENT_SHARED_SECRET=dev-agent-secret
# Secret used to sign dashboard user session JWTs.
JWT_SECRET=dev-jwt-secret

# Reservation lock tuning (seconds). lease = renewed short lock; hard = max session window.
LEASE_TTL_SECONDS=120
HARD_SESSION_SECONDS=2400
# Reconcile loop cadence (seconds).
RECONCILE_INTERVAL_SECONDS=10
# A device is considered offline if no heartbeat within this window (seconds).
HEARTBEAT_TIMEOUT_SECONDS=30

# --- Lab Agent (see lab-agent/.env.example for the full set) ---
# CLOUD_WS_URL=ws://localhost:8080/agent
# DEV_SIMULATE=1
