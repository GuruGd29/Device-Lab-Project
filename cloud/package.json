{
  "name": "cloud",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Device Lab Cloud Control Plane — registry source of truth, auth, assignment + reservation, signaling relay.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@device-lab/contracts": "*",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "fastify": "^4.28.1",
    "jsonwebtoken": "^9.0.2",
    "nats": "^2.28.2",
    "pg": "^8.12.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/ws": "^8.5.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
