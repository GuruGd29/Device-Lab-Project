# Lab Controller Agent — environment. Copy to .env (and `set -a; . ./.env; set +a` or use your
# process manager). Connection + identity + secrets live here; the device inventory lives in
# devices.yaml. Defaults match the cloud plane's .env.example for an out-of-the-box dev run.

# --- Cloud control tunnel ---
CLOUD_WS_URL=ws://localhost:8080/agent
AGENT_ID=lab-agent-01
# MUST match the cloud's AGENT_SHARED_SECRET (presented in the agent.hello frame).
AGENT_SHARED_SECRET=dev-agent-secret
AGENT_VERSION=0.1.0
# AGENT_HOSTNAME=lab-box-01   # defaults to the OS hostname

# --- Local SFU media plane ---
# Advertised to the cloud (dashboards reach the SFU here) AND the bind address. Use a host the
# dashboards can actually reach in production (e.g. http://10.0.0.5:7000), not 0.0.0.0.
SFU_SIGNALING_URL=http://0.0.0.0:7000

# --- Device inventory ---
# DEVICES_YAML=/Users/you/devicelab/devices.yaml   # defaults to <repo>/lab-agent/devices.yaml

# --- Behaviour ---
# DEV_SIMULATE=1 => no hardware: SimAdapter TVs + synthetic camera feeds; calibration QR is
# drawn into the synthetic frame so the QR handshake succeeds end-to-end on a dev laptop.
DEV_SIMULATE=1
CALIBRATION_TIMEOUT_SECONDS=20
RECONNECT_MIN_SECONDS=1
RECONNECT_MAX_SECONDS=30
LOG_LEVEL=INFO

# --- Android TV calibration fallback (optional) ---
# If set, render_qr for Android TVs fires an `am start` VIEW intent at the calibration URL over
# adb-over-network. Without it, Android TV calibration falls back to manual_confirm.
# ADB_PATH=/usr/local/bin/adb

# --- Build install + app management CLIs (optional; only for real hardware) ---
# ADB_PATH (above) is ALSO used to install APKs on Android TVs (adb install / pm list / monkey).
#
# Samsung Tizen (.wgt) install/uninstall + app listing. TIZEN_PATH -> the `tizen` CLI;
# SDB_PATH -> the `sdb` (Smart Development Bridge) used for list/launch and as an install fallback.
# TIZEN_TARGET overrides the sdb/tizen target (defaults to "<net_ip>:26101").
# TIZEN_PATH=/opt/tizen-studio/tools/ide/bin/tizen
# SDB_PATH=/opt/tizen-studio/tools/sdb
# TIZEN_TARGET=10.0.0.11:26101
#
# LG webOS (.ipk) via the ares-* CLI. ARES_PATH points at `ares-install` (siblings ares-launch
# live beside it); ARES_DEVICE selects the device alias from `ares-setup-device` (`-d <name>`).
# ARES_PATH=/opt/webOS_TV_SDK/CLI/bin/ares-install
# ARES_DEVICE=lab-lg-02
